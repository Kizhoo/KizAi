{
  "version": 2,
  "routes": [
    {
      "src": "/api/auth(.*)",
      "dest": "/api/auth.js"
    },
    {
      "src": "/api/chat(.*)",
      "dest": "/api/chat.js"
    },
    {
      "src": "/api/payment(.*)",
      "dest": "/api/payment.js"
    },
    {
      "src": "/api/admin(.*)",
      "dest": "/api/admin.js"
    },
    {
      "src": "/auth",
      "dest": "/auth.html"
    },
    {
      "src": "/chat",
      "dest": "/chat.html"
    },
    {
      "src": "/dashboard",
      "dest": "/dashboard.html"
    },
    {
      "src": "/checkout",
      "dest": "/checkout.html"
    },
    {
      "src": "/tools",
      "dest": "/tools.html"
    },
    {
      "src": "/games",
      "dest": "/games.html"
    },
    {
      "src": "/leaderboard",
      "dest": "/leaderboard.html"
    },
    {
      "src": "/admin",
      "dest": "/admin.html"
    },
    {
      "src": "/admin-login",
      "dest": "/admin-login.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
