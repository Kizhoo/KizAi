{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/auth(.*)",
      "dest": "/api/auth.js"
    },
    {
      "src": "/api/chat(.*)",
      "dest": "/api/chat.js"
    },
    {
      "src": "/api/payment(.*)",
      "dest": "/api/payment.js"
    },
    {
      "src": "/api/admin(.*)",
      "dest": "/api/admin.js"
    },
    {
      "src": "/games",
      "dest": "/public/games.html"
    },
    {
      "src": "/tools",
      "dest": "/public/tools.html"
    },
    {
      "src": "/chat",
      "dest": "/public/chat.html"
    },
    {
      "src": "/checkout",
      "dest": "/public/checkout.html"
    },
    {
      "src": "/dashboard",
      "dest": "/public/dashboard.html"
    },
    {
      "src": "/auth",
      "dest": "/public/auth.html"
    },
    {
      "src": "/admin",
      "dest": "/public/admin.html"
    },
    {
      "src": "/admin-login",
      "dest": "/public/admin-login.html"
    },
    {
      "src": "/leaderboard",
      "dest": "/public/leaderboard.html"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}