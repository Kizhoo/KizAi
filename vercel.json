{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**",   "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/auth(.*)",    "dest": "/api/auth.js" },
    { "src": "/api/chat(.*)",    "dest": "/api/chat.js" },
    { "src": "/api/payment(.*)", "dest": "/api/payment.js" },
    { "src": "/api/admin(.*)",   "dest": "/api/admin.js" },
    { "src": "/dashboard",       "dest": "/dashboard.html" },
    { "src": "/auth",            "dest": "/auth.html" },
    { "src": "/chat",            "dest": "/chat.html" },
    { "src": "/checkout",        "dest": "/checkout.html" },
    { "src": "/tools",           "dest": "/tools.html" },
    { "src": "/games",           "dest": "/games.html" },
    { "src": "/admin",           "dest": "/admin.html" },
    { "src": "/admin-login",     "dest": "/admin-login.html" },
    { "src": "/",                "dest": "/index.html" },
    { "src": "/(.*)",            "dest": "/$1" }
  ]
}
