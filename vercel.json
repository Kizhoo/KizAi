{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/auth/:path*",    "destination": "/api/auth" },
    { "source": "/api/chat/:path*",    "destination": "/api/chat" },
    { "source": "/api/payment/:path*", "destination": "/api/payment" },
    { "source": "/api/admin/:path*",   "destination": "/api/admin" },
    { "source": "/chat",        "destination": "/public/chat.html" },
    { "source": "/auth",        "destination": "/public/auth.html" },
    { "source": "/dashboard",   "destination": "/public/dashboard.html" },
    { "source": "/checkout",    "destination": "/public/checkout.html" },
    { "source": "/tools",       "destination": "/public/tools.html" },
    { "source": "/games",       "destination": "/public/games.html" },
    { "source": "/leaderboard", "destination": "/public/leaderboard.html" },
    { "source": "/admin",       "destination": "/public/admin.html" },
    { "source": "/admin-login", "destination": "/public/admin-login.html" },
    { "source": "/shared.css",  "destination": "/public/shared.css" },
    { "source": "/shared.js",   "destination": "/public/shared.js" },
    { "source": "/manifest.json","destination": "/public/manifest.json" },
    { "source": "/",            "destination": "/public/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization,X-Stream" }
      ]
    },
    {
      "source": "/shared.(css|js)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
    }
  ]
}
